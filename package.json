{
  "name": "easy-pandoc-gui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm -r build",
    "check:format": "prettier --check .",
    "cli": "pnpm --filter @testpandoc/cli cli",
    "desktop:dev": "pnpm --filter @testpandoc/desktop dev",
    "desktop:tauri:build": "pnpm --filter @testpandoc/desktop tauri:build",
    "desktop:tauri:dev": "pnpm --filter @testpandoc/desktop tauri:dev",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "husky",
    "version:check": "node scripts/check-version-consistency.mjs",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^8.0.8",
    "vitest": "^3.1.2"
  }
}
